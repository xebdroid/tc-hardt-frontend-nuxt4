<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Existierende Dateien (wie send-mail.php, Bilder, CSS) direkt ausliefern
    # Das verhindert, dass API-Calls oder Assets kaputt gehen.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. Option A: Wenn du 'nuxt generate' nutzt (SSG)
    # Nuxt generiert eine 404.html. Wir sagen dem Server, er soll diese nutzen.
    ErrorDocument 404 /404.html
    # 403 (Verboten) leiten wir auch auf die 404-Seite um, das ist sicherer/sauberer
    ErrorDocument 403 /404.html

    # Optional: Eigene Fehlerseite für Server-Fehler (500)
    # Dafür müsstest du eine 500.html manuell im public-Ordner anlegen.
    ErrorDocument 500 /500.html

    # 3. Option B: Fallback auf index.html (SPA-Verhalten)
    # Wenn keine 404.html existiert oder du 'nuxt build' nutzt,
    # leite alles andere auf die Startseite um, damit Nuxt das Routing übernimmt.
    # WICHTIG: Verhindern, dass fehlende Assets (Bilder, JS, CSS) die App laden.
    # Sie sollen einen echten 404-Fehler werfen (und damit ErrorDocument 404 auslösen).
    RewriteCond %{REQUEST_URI} !\.(css|js|mjs|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|map)$ [NC]
    RewriteRule ^ index.html [L]
</IfModule>
