# Standard-Fehlerdokumente für den Apache-Server festlegen
ErrorDocument 400 /404.html
ErrorDocument 401 /404.html
ErrorDocument 403 /403/index.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500/index.html
ErrorDocument 502 /500/index.html
ErrorDocument 503 /500/index.html
ErrorDocument 504 /500/index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- 301 Weiterleitungen von alten URLs ---

  # Spezifische Weiterleitungen
  RewriteRule ^index\.php/vorstand\.html$ /vorstand [R=301,L]
  RewriteRule ^index\.php/tennisschule\.html$ /training [R=301,L]
  RewriteRule ^index\.php/kontakt\.html$ /kontakt [R=301,L]
  RewriteRule ^index\.php/50-jahre-tc-hardt\.html$ /50-jahre-tc-hardt [R=301,L]

  # Genereller Fallback für alles andere, was mit index.php beginnt
  RewriteRule ^index\.php/?(.*)$ / [R=301,L]


  # --- Nuxt Routing & Fallbacks ---

  # Endlosschleifen verhindern (Pfade an Nuxt-Struktur angepasst)
  RewriteCond %{REQUEST_URI} ^/404\.html$ [OR]
  RewriteCond %{REQUEST_URI} ^/(403|500)/index\.html$
  RewriteRule ^ - [L]

  # Echte Dateien oder Ordner direkt ausliefern
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Alles andere wirft einen 404 Fehler
  RewriteRule ^ - [R=404,L]
</IfModule>
