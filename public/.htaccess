# Standard-Fehlerdokumente für den Apache-Server festlegen
ErrorDocument 400 /404.html
ErrorDocument 401 /404.html
ErrorDocument 403 /403/index.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500/index.html
ErrorDocument 502 /500/index.html
ErrorDocument 503 /500/index.html
ErrorDocument 504 /500/index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- 301 Weiterleitungen von alten URLs ---

  # Sonderfall: PDF Download (muss VOR dem allgemeinen Anmeldung.html stehen wegen Query-String)
  RewriteCond %{QUERY_STRING} file=tl_files/tc-hardt/Downloads/Aufnahmeantrag_TC%20Hardt\.pdf [NC]
  RewriteRule ^index\.php/Anmeldung\.html$ /downloads/aufnahmeantrag-tc-hardt.pdf? [R=301,L]

  # Spezifische Weiterleitungen (A-Z)
  RewriteRule ^index\.php/Anmeldung\.html$ /mitglied-werden [R=301,L]
  RewriteRule ^index\.php/Damen_55\.html$ /mannschaften [R=301,L]
  RewriteRule ^index\.php/datenschutz\.html$ /datenschutz [R=301,L]
  RewriteRule ^index\.php/erwachsene\.html$ /mannschaften [R=301,L]
  RewriteRule ^index\.php/Herren\.html$ /mannschaften [R=301,L]
  RewriteRule ^index\.php/Herren_50\.html$ /mannschaften [R=301,L]
  RewriteRule ^index\.php/impressum\.html$ /impressum [R=301,L]
  RewriteRule ^index\.php/kontakt\.html$ /kontakt [R=301,L]
  RewriteRule ^index\.php/Oster_und_Sommer_Tennis_Camps\.html$ /training [R=301,L]
  RewriteRule ^index\.php/Schnupperangebot\.html$ /mitglied-werden#tarife [R=301,NE,L]
  RewriteRule ^index\.php/Tennis_AG\.html$ /training [R=301,L]
  RewriteRule ^index\.php/tennisschule\.html$ /training [R=301,L]
  RewriteRule ^index\.php/terminuebersicht\.html$ /termine [R=301,L]
  RewriteRule ^index\.php/vorstand\.html$ /vorstand [R=301,L]
  RewriteRule ^index\.php/50-jahre-tc-hardt\.html$ /50-jahre-tc-hardt [R=301,L]

  # URL ohne index.php
  RewriteRule ^damen-offene-klasse\.html$ /mannschaften [R=301,L]

  # Genereller Fallback für alles andere, was mit index.php beginnt
  RewriteRule ^index\.php/?(.*)$ / [R=301,L]


  # --- Nuxt Routing & Fallbacks ---

  # Endlosschleifen verhindern (Pfade an Nuxt-Struktur angepasst)
  RewriteCond %{REQUEST_URI} ^/404\.html$ [OR]
  RewriteCond %{REQUEST_URI} ^/(403|500)/index\.html$
  RewriteRule ^ - [L]

  # Echte Dateien oder Ordner direkt ausliefern
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Alles andere wirft einen 404 Fehler
  RewriteRule ^ - [R=404,L]
</IfModule>
