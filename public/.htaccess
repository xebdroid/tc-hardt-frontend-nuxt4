ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Verhindere Endlosschleifen für die Fehlerseite
  RewriteCond %{REQUEST_URI} ^/404.html$
  RewriteRule ^ - [L]

  # Wenn die Datei existiert (Bild, PDF, etc.), liefere sie direkt aus
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Alles andere an Nuxt übergeben
  RewriteRule . /index.html [L]
</IfModule>
